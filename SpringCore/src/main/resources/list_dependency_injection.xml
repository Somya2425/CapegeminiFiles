<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
http://www.springframework.org/schema/beans
http://www.springframework.org/schema/beans/spring-beans.xsd">
    <bean id = "list1" class ="dependancy_injection.Library">
        <property name="name" value="ss"></property>
        <property name="id" value="2"></property>
        <property name="pans" >
            <list>
                <ref bean="pans1"/>
                <ref bean="pans2"/>
            </list>
        </property>

    </bean>
    <bean id = "pans1" class = "dependancy_injection.Pan">
        <property name="panName" value="pan"></property>
        <property name="panId" value="76"></property>
    </bean>

    <bean id = "pans2" class = "dependancy_injection.Pan">
        <property name="panName" value="pann"></property>
        <property name="panId" value="78"></property>
    </bean>
    </beans>